<!--
════════════════════════════════════════════════════════
  PASTE INTO:  android/app/src/main/AndroidManifest.xml
  LOCATION:    BEFORE the <application ...> tag
════════════════════════════════════════════════════════
-->

<!-- Microphone — required for speech recognition -->
<uses-permission android:name="android.permission.RECORD_AUDIO" />

<!-- Internet — required for Claude & Sarvam.ai API calls -->
<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

<!-- Audio — for in-ear monitoring during interpretation -->
<uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

<!-- Keep screen on during active interpretation session -->
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!--
════════════════════════════════════════════════════════
  PASTE INSIDE the <application ...> tag
  (enables Android speech recognition service query)
════════════════════════════════════════════════════════
-->
<queries>
    <intent>
        <action android:name="android.speech.RecognitionService" />
    </intent>
</queries>

<!--
════════════════════════════════════════════════════════
  FOR PLAY STORE — also add inside <application> tag:
  (RevenueCat billing requires this)
════════════════════════════════════════════════════════
-->
<uses-permission android:name="com.android.vending.BILLING" />
